# Copia este archivo a .env.local para desarrollo local (no se sube a git).
# En producción (Vercel), estas variables se configuran en
# Project Settings → Environment Variables.

# Se agrega automáticamente al conectar una base de datos Postgres/Neon
# desde el dashboard de Vercel (Storage → Create Database).
DATABASE_URL=

# Usuario y clave para entrar a /admin. Si no se configuran, se usan
# los valores por defecto: gino / gino123
ADMIN_USERNAME=gino
ADMIN_PASSWORD=gino123
